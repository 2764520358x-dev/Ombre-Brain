# Cyberboss 配置文件（已按用户需求配置完毕）
# 使用前将本文件复制为 .env，并填入 CYBERBOSS_ALLOWED_USER_IDS

# ── 用户身份 ──────────────────────────────────────────────────
CYBERBOSS_USER_NAME=慢
CYBERBOSS_USER_GENDER=female

# ── 工作区（指向本项目根目录）────────────────────────────────
CYBERBOSS_WORKSPACE_ROOT=/absolute/path/to/Ombre-Brain

# ── 运行时：Claude Code ───────────────────────────────────────
CYBERBOSS_RUNTIME=claudecode

# ── 微信允许的用户 ID（首次 login 扫码后，用微信的账户 ID 填入）
# 可通过 npm run accounts 查看已登录账户的 ID
# CYBERBOSS_ALLOWED_USER_IDS=your_weixin_id_here

# ── 随机轮询（Stochastic Pulse）───────────────────────────────
CYBERBOSS_ENABLE_CHECKIN=true
# 启动后在微信发送 /checkin 20-60 可调整随机间隔（单位：分钟）

# ── 状态目录 ──────────────────────────────────────────────────
CYBERBOSS_STATE_DIR=/root/.cyberboss

# ── Claude 运行时参数 ─────────────────────────────────────────
CYBERBOSS_CLAUDE_COMMAND=claude
CYBERBOSS_CLAUDE_PERMISSION_MODE=default

# ── Ombre-Brain 记忆系统 ──────────────────────────────────────
# MCP 服务器已通过 setup.sh 写入 Claude Code 配置，无需额外配置
# 主端点：https://ombre-brain-1.onrender.com/mcp
# 副端点：https://ombre-brain-1.onrender.com/mcp-extra
